# ──────────────────────────────────────────────────────────────
# Magic Key Assistant — Environment Variables
# ──────────────────────────────────────────────────────────────
# For LOCAL development:
#   Copy to LeisureLLM/.env  (the setup wizard does this for you)
#
# For DOCKER:
#   Copy to .env at this repo root
#   docker compose up --build
#
# .env is gitignored and should NEVER be committed.
# ──────────────────────────────────────────────────────────────

# Required: Discord Bot Token
# Get from: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Required: OpenAI API Key
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Required: Discord Server (Guild) ID
# Right-click your server → Copy Server ID (enable Developer Mode first)
SERVER_ID=0

# Optional: Tavily API Key (for web search — accelerator mode only)
# Get free tier: https://tavily.com
TAVILY_API_KEY=

# ── Discord Channel Overrides ────────────────────────────────
# Set via /set_bots_channel in Discord, or fill in here
# BOTS_OFFICE_CHANNEL_ID=0
# SCHEMES_DREAMS_CHANNEL_ID=0

# ── Database ──────────────────────────────────────────────────
# Path to SQLite database file (relative to LeisureLLM/ directory)
DATABASE_PATH=assistant.db

# ── Optional: Chroma / Docs directories ──────────────────────
# PERSIST_DIRECTORY=chroma_v3
# DOCS_DIRECTORY=docs
